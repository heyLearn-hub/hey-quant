#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="$ROOT/.venv/bin/python"

if [[ ! -x "$PYTHON_BIN" ]]; then
  echo "Missing virtualenv Python: $PYTHON_BIN" >&2
  echo "Run: python3 -m venv .venv && .venv/bin/python -m pip install -e '.[dev]'" >&2
  exit 1
fi

export PYTHONPATH="$ROOT/src${PYTHONPATH:+:$PYTHONPATH}"

if [[ -f "$ROOT/.env" ]]; then
  PRESERVE_ENV_NAMES=(
    FMP_API_KEY
    DEEPSEEK_API_KEY
    OPENAI_API_KEY
    TELEGRAM_BOT_TOKEN
    TELEGRAM_CHAT_ID
    SMTP_USERNAME
    SMTP_PASSWORD
    SMTP_FROM
    SMTP_TO
  )
  for name in "${PRESERVE_ENV_NAMES[@]}"; do
    if [[ -n "${!name-}" ]]; then
      export "__QUANT_AI_PRESERVE_$name=${!name}"
    fi
  done
  set -a
  # shellcheck disable=SC1091
  source "$ROOT/.env"
  set +a
  for name in "${PRESERVE_ENV_NAMES[@]}"; do
    preserved_name="__QUANT_AI_PRESERVE_$name"
    if [[ -n "${!preserved_name-}" ]]; then
      export "$name=${!preserved_name}"
      unset "$preserved_name"
    fi
  done
fi

exec "$PYTHON_BIN" -m quant_ai_system.cli "$@"
