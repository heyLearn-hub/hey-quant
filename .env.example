# Copy this file to .env on the machine that runs the system.
# Do not commit .env.

# Optional AI Supervisor review. Keep real keys in .env only.
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# Optional paid market data.
# FMP_API_KEY=

# Telegram bot notification. Keep the real token in .env only.
TELEGRAM_BOT_TOKEN=replace_with_botfather_token
TELEGRAM_CHAT_ID=replace_with_your_chat_id

# Outlook / SMTP email.
SMTP_USERNAME=your_outlook_email@example.com
SMTP_PASSWORD=your_smtp_or_app_password
SMTP_FROM=your_outlook_email@example.com
SMTP_TO=recipient@example.com
